#!/bin/bash
# =============================================================================
# vpn-LUH.sh - University of Hannover VPN connection script
# =============================================================================
# Connects to the Leibniz University Hannover VPN using OpenConnect.
# Symlinked to /usr/local/bin for global access.
# =============================================================================

VPN_SERVER="vpn-server.uni-hannover.de"

# Retrieve credentials from the login keychain.
# One-time setup (run once per machine):
#   security add-generic-password -a "your-uni-id" -s "vpn-luh" -w "yourpassword" login.keychain
USERNAME=$(security find-generic-password -s "vpn-server.uni-hannover.de" 2>/dev/null | awk -F'"' '/"acct"/{print $4}')
PASSWORD=$(security find-generic-password -s "vpn-server.uni-hannover.de" -w 2>/dev/null)

if [[ -z "$USERNAME" || -z "$PASSWORD" ]]; then
    echo "[ERROR] VPN credentials not found in login keychain."
    echo "Run: security add-generic-password -a \"your-uni-id\" -s \"vpn-server.uni-hannover.de\" -w \"yourpassword\" login.keychain"
    exit 1
fi

echo "$PASSWORD" | sudo openconnect --user="$USERNAME" --passwd-on-stdin "${VPN_SERVER}"
