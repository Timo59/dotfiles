% =============================================================================
% exercise.sty - LaTeX package for exercise sheets
% =============================================================================
% Builds on base.sty and adds:
%   - Common state vectors (|0>, |1>, |+>, |->)
%   - Exercise and remark environments with auto-numbering
%   - Quantum circuit support (qcircuit, tikz)
%   - Hyperref configuration for PDF output
% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{exercise}[2026/01/14 LaTeX package for exercises]

\RequirePackage{base}
\SetLabelAlign{LeftAlignFullWidth}{\makebox[\dimexpr\linewidth+\labelwidth\relax][l]{#1}}
\RequirePackage[pdfnewwindow=true, breaklinks=true]{hyperref}
	\hypersetup{%
		colorlinks=true,
		linkcolor=blue,
		citecolor=black,
	}%
\RequirePackage{qcircuit}
\RequirePackage{tikz}
\usetikzlibrary{positioning, decorations.pathreplacing}

\RequirePackage{subfiles}
	\ifSubfilesClassLoaded{%
	}{%
		\renewcommand{\thesection}{\Roman{section}}%
	}%

		
%%% SPECIFIC
	\newcommand*{\zero}{\ket{0}}%				% +1 eigenstate of Pauli-Z
    \newcommand*{\one}{\ket{1}}%				% -1 eigenstate of Pauli-Z
	\newcommand*{\plus}{\ket{+}}%				% +1 eigenstate of Pauli-X
	\newcommand*{\minus}{\ket{-}}%				% -1 eigenstate of Pauli-X
    \newcommand*{\up}{\ket{\uparrow}}%			% +1 eigenstate of Pauli-Y
	\newcommand*{\down}{\ket{\downarrow}}%		% -1 eigenstate of Pauli-Y
                
    \newcommand*{\channel}{\mathcal{E}}%		% General quantum channel

    \counterwithin{equation}{section}

%%% ENIVRONMENTS
 	\newcounter{Exercise}[section]
	\counterwithin{Exercise}{section} %connects section counter to exercise counter
	\def\Exerciseautorefname{Exercise}
	\newenvironment{exercise}[1]{\refstepcounter{Exercise}\par\medskip \noindent \textbf{Exercise \theExercise:} \textit{#1}\par\medskip}{\medskip}

	\newcounter{Remark}[section]
	\counterwithin{Remark}{section} %connects section counter to remark counter
	\def\Remarkautorefname{Remark}
	\newenvironment{remark}[1]{\refstepcounter{Remark}\par\medskip \noindent \color{gray}\textbf{Remark \theRemark:} \textit{#1}\par\medskip}{\medskip}
