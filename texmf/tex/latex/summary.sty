% =============================================================================
% summary.sty - LaTeX package for paper summaries
% =============================================================================
% Compact layout for summarizing research papers. Includes base.sty macros
% with A4 paper, narrow margins (1.5cm), and parskip formatting.
% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{summary}[2025/08/27 LaTeX package for paper summaries]

\RequirePackage{base}
\RequirePackage{enumitem}
\SetLabelAlign{LeftAlignFullWidth}{\makebox[\dimexpr\linewidth+\labelwidth\relax][l]{#1}}
\RequirePackage[pdfnewwindow=true, breaklinks=true]{hyperref}
	\hypersetup{%
		colorlinks=true,
		linkcolor=blue,
		citecolor=black,
	}%
\RequirePackage{parskip}
\RequirePackage{qcircuit}
\RequirePackage{tikz}
\usetikzlibrary{positioning, decorations.pathreplacing}

\RequirePackage[a4paper, margin=1.5cm]{geometry}



%%% MACROS
	\newcommand{\RN}[1]{\uppercase\expandafter{\romannumeral #1\relax}}	% Roman numerals